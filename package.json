{
	"name": "codeteleport",
	"version": "0.2.1",
	"description": "Teleport AI coding sessions between machines",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/korvol/codeteleport"
	},
	"keywords": ["claude", "claude-code", "mcp", "sync", "teleport", "sessions"],
	"bin": {
		"codeteleport": "./dist/cli/index.js",
		"codeteleport-mcp": "./dist/mcp/index.js"
	},
	"main": "./dist/index.js",
	"files": ["dist", "README.md"],
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1",
		"commander": "^12",
		"open": "^10",
		"tar": "^7",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/node": "^20",
		"typescript": "^5.5",
		"vitest": "^2"
	}
}
